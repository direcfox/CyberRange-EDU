services:
  attacker:
    build: .
    container_name: attacker-machine
    hostname: attacker
    ports:
      - "8082:80"
    volumes:
      - ./www:/var/www/html
    depends_on:
      - mysql
    networks:
      - attack-lab
    tty: true
    stdin_open: true 

mysql:
  image: mysql:8.0 
  container_name: attacker-mysql
  environment:
    MYSQL_ROOT_PASSWORD: rootpass
    MYSQL_DATABASE: attackerdb
    MYSQL_USER: attacker
    MYSQL_PASSWORD: attakeerpa
exit

exit



